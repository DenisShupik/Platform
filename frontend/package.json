{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"openapi-ts": "openapi-ts",
		"update-shadcn": "pnpm dlx shadcn-svelte@latest add --overwrite --yes avatar badge breadcrumb button card checkbox collapsible command dialog dropdown-menu form input input-group label pagination popover scroll-area select separator spinner sheet switch textarea"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "latest",
		"@hey-api/openapi-ts": "0.97.0",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "1.14.0",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.58.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.4",
		"better-auth": "^1.6.9",
		"bits-ui": "2.18.0",
		"clsx": "2.1.1",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"formsnap": "2.0.1",
		"globals": "17.5.0",
		"mode-watcher": "1.1.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "5.55.5",
		"svelte-check": "4.4.6",
		"sveltekit-superforms": "2.30.1",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.1",
		"unplugin-icons": "^23.0.1",
		"valibot": "^1.3.1",
		"vite": "^8.0.10",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@iconify-json/tabler": "^1.2.33"
	}
}
