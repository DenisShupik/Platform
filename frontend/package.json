{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"openapi-ts": "openapi-ts",
		"update-shadcn": "pnpm dlx shadcn-svelte@latest add --overwrite --yes avatar badge breadcrumb button card checkbox collapsible command dialog dropdown-menu form input input-group label pagination popover scroll-area select separator spinner sheet switch textarea"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "latest",
		"@hey-api/openapi-ts": "0.0.0-next-20260720171903",
		"@internationalized/date": "3.12.2",
		"@lucide/svelte": "1.25.0",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-node": "5.5.7",
		"@sveltejs/kit": "2.70.1",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.3",
		"better-auth": "1.6.23",
		"bits-ui": "2.18.1",
		"clsx": "2.1.1",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.22.0",
		"formsnap": "2.0.1",
		"globals": "17.7.0",
		"mode-watcher": "1.1.0",
		"prettier": "3.9.5",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "5.56.6",
		"svelte-check": "4.7.3",
		"sveltekit-superforms": "2.30.2",
		"tailwind-merge": "3.6.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.3.3",
		"tw-animate-css": "1.4.0",
		"typescript": "7.0.2",
		"typescript-eslint": "8.64.0",
		"unplugin-icons": "23.0.1",
		"valibot": "1.4.2",
		"vite": "8.1.5",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@iconify-json/tabler": "1.2.36"
	}
}
